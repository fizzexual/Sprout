{
  "name": "botanica",
  "version": "0.1.0",
  "private": true,
  "description": "Botanica — a professional code editor for the Sprout programming language.",
  "author": "Fizzexual",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "powershell -ExecutionPolicy Bypass -File make-icon.ps1 -Out build/icon.ico && electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "monaco-editor": "^0.52.0"
  },
  "build": {
    "appId": "com.sprout.botanica",
    "productName": "Botanica",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "index.html", "renderer.js", "sprout-language.js", "styles.css"],
    "extraResources": [{ "from": "../src", "to": "sprout-src" }],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Botanica"
    }
  }
}
