~ Your very first Sprout program!
~ Run it with:  sprout run examples/hello.sprout

show "Hello, world!"

make name = "friend"
show "Nice to meet you, " + name + "!"

~ Numbers and math
make a = 7
make b = 6
show a, "+", b, "=", a + b
show a, "times", b, "=", a * b

~ yes / no
make sunny = yes
when sunny:
    show "Let's go outside."
otherwise:
    show "Let's stay in."
