~ Sprout's built-in functions.

show "abs(-4)    =", abs(-4)
show "round(3.7) =", round(3.7)
show "floor(3.7) =", floor(3.7)
show "ceil(3.2)  =", ceil(3.2)
show "sqrt(144)  =", sqrt(144)
show "max(2,9,5) =", max(2, 9, 5)
show "min(2,9,5) =", min(2, 9, 5)

show ""
make word = "Sprout"
show word, "has", length(word), "letters"
show "shout: " + upper(word)
show "quiet: " + lower(word)
