~ Draw a little triangle of stars using loops and text.

make row = 1
repeat while row <= 6:
    make stars = ""
    make i = 0
    repeat while i < row:
        set stars = stars + "*"
        set i = i + 1
    show stars
    set row = row + 1

show ""
show "Countdown:"
make count = 5
repeat 5 times:
    show count
    set count = count - 1
show "Liftoff! 🚀"
