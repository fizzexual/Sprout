~ A tiny GUI that greets you by name.
~ Run it with:  sprout gui examples/gui-greeter.sprout

task greet():
    make who = textof("name")
    when who == "":
        set who = "stranger"
    label("greeting", "Hello, " + who + "! 🌱")

window("Greeter")
field("name", "Type your name")
label("greeting", "Hello!")
button("Greet me", "greet")
