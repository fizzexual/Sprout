~ Print every prime number up to 30.
~ A number is prime if nothing divides it evenly except 1 and itself.

show "Primes up to 30:"

make n = 2
repeat while n <= 30:
    make isPrime = yes
    make d = 2
    repeat while d * d <= n:
        when n % d == 0:
            set isPrime = no
        set d = d + 1
    when isPrime:
        show n
    set n = n + 1
