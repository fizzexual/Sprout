~ The classic FizzBuzz, in Sprout.
~ Count to 20: multiples of 3 -> Fizz, of 5 -> Buzz, of both -> FizzBuzz.

make n = 1
repeat while n <= 20:
    when n % 15 == 0:
        show "FizzBuzz"
    orwhen n % 3 == 0:
        show "Fizz"
    orwhen n % 5 == 0:
        show "Buzz"
    otherwise:
        show n
    set n = n + 1
