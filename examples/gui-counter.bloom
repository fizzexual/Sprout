~ A Bloom theme for the counter app.
~ Bloom is Sprout's styling language. A .bloom file sitting next to a .sprout
~ file is loaded automatically, so gui-counter.sprout gets this look for free.

window:
    background: #1a1030
    text: #f0e9ff
    font: Segoe UI 14

#display:
    size: 26
    text: #c9a8ff

button:
    background: #8a5cff
    text: #ffffff
    rounded: 12
