~ A Bloom theme for the counter app.
~ Bloom is Sprout's styling language. gui-counter.sprout loads it with:
~     style "gui-counter.bloom"

window:
    background: #1a1030
    text: #f0e9ff
    font: Segoe UI 14

#display:
    size: 50
    text: #c9a8ff

button:
    background: #8a5cff
    text: #ffffff
    rounded: 12
