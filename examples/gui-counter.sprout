~ A clickable counter — your first Sprout GUI app!
~ Just open this file to run it (or: sprout gui examples/gui-counter.sprout).

style "gui-counter.bloom"

make count = 0

task add():
    set count = count + 1
    label("display", "Count: " + count)

task reset():
    set count = 0
    label("display", "Count: 0")

window("Counter")
label("display", "Count: 0")
button("Add one", "add")
button("Reset", "reset")
