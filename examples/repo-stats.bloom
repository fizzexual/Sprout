~ A GitHub-style dark theme for the repo stats app.

window:
    background: #0d1117
    text: #c9d1d9
    font: Segoe UI 13

#name:
    size: 20
    text: #58a6ff

#stats:
    size: 15

button:
    background: #238636
    text: #ffffff
    rounded: 8
    padding: 8

field:
    background: #010409
    text: #c9d1d9
    border: #30363d
    padding: 8
