node_modules/
dist/
# ...but DO ship the built installer so people can download + run it.
!installer/dist/
installer/dist/*
!installer/dist/SproutSetup.exe
*.log
logs.txt
.DS_Store

# Data saved by Sprout programs (remember/recall)
*.data.json

# Secrets read by secret("NAME") — these stay on your computer, never on GitHub.
# (.env.example is a safe, token-free template and IS committed.)
.env
*.env
!*.env.example

# Packaged VS Code extension
*.vsix

# Local editor / tooling state
.claude/

# Botanica's generated app icon + build output (recreated by the scripts)
botanica/icon.ico
botanica/build/

