node_modules/
dist/
# The installer EXE is published to GitHub Releases by CI, not committed.
*.log
logs.txt
.DS_Store

# Data saved by Sprout programs (remember/recall)
*.data.json

# Secrets read by secret("NAME") — these stay on your computer, never on GitHub.
# (.env.example is a safe, token-free template and IS committed.)
.env
*.env
!*.env.example

# Packaged VS Code extension
*.vsix

# Local editor / tooling state
.claude/

# Botanica's generated app icon + build output (recreated by the scripts)
botanica/icon.ico
botanica/build/

# Build artifacts — the interpreter exe is published to Releases, never committed.
*.exe

# Stray scratch / probe files. Real source lives in src/, src/tests/, modules/, etc.;
# loose .sprout files at the repo root are throwaway experiments, not source.
/*.sprout
src/test_inf_behavior.sprout
src/test_inf_json.sprout
src/test_inf_sort.sprout
src/test_infinity.sprout
src/test_json_inf.sprout
src/test_nan_behavior.sprout

