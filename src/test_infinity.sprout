show "Testing large pow:"
show pow(10, 308)
show pow(10, 309)
show pow(10, 310)
show "Testing sqrt of negative:"
try:
    show sqrt(-1)
caught e:
    show "sqrt error:", e["message"]
show "Testing division by zero (indirectly via pow):"
try:
    show pow(0, -1)
caught e:
    show "pow error:", e["message"]
show "Testing number() with inf:"
show number("inf")
show number("nan")
