~ exercises the `use` module loader + namespaced access (module.name)
use "tests/lib.sprout"

when lib.triple(4) == 12:
    show "ok: lib.triple()"
otherwise:
    show "FAIL: lib.triple()"

when lib.shout("hi") == "HI!":
    show "ok: lib.shout()"
otherwise:
    show "FAIL: lib.shout()"

~ using the same module twice must be a no-op (loads once), not an error
use "tests/lib.sprout"
show "ok: re-use is harmless"
