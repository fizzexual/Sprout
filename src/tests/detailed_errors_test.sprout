~ Detailed, value-aware errors (the "name the thing that broke" pass).
~ Every error now names which input, its real type + value, and a fix. This test
~ pins the error `kind` contract for each failure mode, so the messages can keep
~ improving without silently drifting between kinds.
~ A *_test.sprout file: run.sh gates it via `sprout test` (exit code). All PASS.

test "a built-in called the wrong way -> kind 'error'":
    expect error "error":
        show abs("x")
    expect error "error":
        show sqrt("x")
    expect error "error":
        show map(5, 5)
    expect error "error":
        show add(5, 9)
    expect error "error":
        show pow(2)
    expect error "error":
        show range("5")
    expect error "error":
        show upper(42)
    expect error "error":
        show keys([1, 2])
    expect error "error":
        show sort_by([1, 2], 3)

test "operators on the wrong kinds -> kind 'type'":
    expect error "type":
        show [1, 2] + 5
    expect error "type":
        show "hi" - 3
    expect error "type":
        show 1 < "a"

test "list item / argument element checks -> kind 'type'":
    expect error "type":
        show sum([1, "a"])
    expect error "type":
        show min([1, "a"])

test "indexing out of range -> kind 'index'":
    expect error "index":
        make xs = [10, 20]
        show xs[99]
    expect error "index":
        show "hi"[99]
    expect error "index":
        make xs = [1, 2]
        remove(xs, 50)
    expect error "index":
        make xs = [1, 2]
        set xs[99] = 7

test "indexing with the wrong kind -> kind 'type'":
    expect error "type":
        make xs = [1, 2]
        show xs["k"]
    expect error "type":
        make xs = [1, 2]
        show xs[1.5]
    expect error "type":
        make m = {a: 1}
        show m[0]

test "math with no answer -> kind 'math'":
    expect error "math":
        show 1 / 0
    expect error "math":
        show sqrt(-1)
