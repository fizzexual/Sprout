~ regex: alternation, capture groups, captures(), quantified groups (v0.1.17 engine)

test "alternation":
    expect matches("dog", "cat|dog") == yes
    expect matches("cat", "cat|dog") == yes
    expect matches("cow", "cat|dog") == no
    expect matches("grey", "gr(a|e)y") == yes
    expect matches("gray", "gr(a|e)y") == yes

test "capture groups via captures()":
    make c = captures("12-34", "([0-9]+)-([0-9]+)")
    expect c[0] == "12-34"
    expect c[1] == "12"
    expect c[2] == "34"

test "captures returns nothing when there is no match":
    expect captures("nope", "([0-9]+)") == nothing

test "quantified group":
    expect matches("ababab", "(ab)+") == yes
    expect matches("abab", "(ab)+c") == no

test "find_all with alternation":
    make hits = find_all("cat dog cat bird dog", "cat|dog")
    expect length(hits) == 4
    expect hits[0] == "cat"
    expect hits[3] == "dog"

test "classes and anchors still work":
    expect matches("hello", "[a-z]+") == yes
    expect matches("Hi", "[a-z]+") == no
    expect matches("abc", "^a.c$") == yes
    expect length(find_all("order 42, ref 1009", "[0-9]+")) == 2
