~ Slice sugar: xs[a:b] takes a sub-range (end exclusive). Either bound may be omitted
~ (xs[a:], xs[:b], xs[:]) and either may be negative (from the end). Works on lists and
~ text (UTF-8 aware). A *_test.sprout file, gated by `sprout test`.

test "list slices":
    make xs = [10, 20, 30, 40, 50]
    expect xs[1:3] == [20, 30]
    expect xs[:2] == [10, 20]
    expect xs[3:] == [40, 50]
    expect xs[-2:] == [40, 50]
    expect xs[1:-1] == [20, 30, 40]
    expect xs[:] == xs
    expect xs[10:20] == []

test "text slices":
    expect "sprouting"[0:3] == "spr"
    expect "sprouting"[-3:] == "ing"
    expect "hello"[1:4] == "ell"
    expect "hello"[:] == "hello"
