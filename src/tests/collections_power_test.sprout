~ Collection power tools: group_by / min_by / max_by / partition / chunk.
~ A *_test.sprout file (gated via `sprout test`).

test "group_by buckets items by a key (insertion order kept)":
    make xs = [{"t": "a", "v": 1}, {"t": "b", "v": 2}, {"t": "a", "v": 3}]
    make g = group_by(xs, task(x): x["t"])
    expect keys(g) == ["a", "b"]
    expect length(g["a"]) == 2
    expect length(g["b"]) == 1

test "min_by / max_by pick the extreme item (numeric key)":
    make ps = [{"n": "pen", "p": 3}, {"n": "mug", "p": 9}, {"n": "cap", "p": 5}]
    expect min_by(ps, task(x): x["p"])["n"] == "pen"
    expect max_by(ps, task(x): x["p"])["n"] == "mug"
    expect min_by([], task(x): x) == nothing

test "min_by / max_by also work on text keys":
    make words = ["pear", "apple", "fig"]
    expect min_by(words, task(w): w) == "apple"
    expect max_by(words, task(w): w) == "pear"

test "partition splits into [matches, rest]":
    make r = partition([1, 2, 3, 4, 5, 6], task(n): n % 2 == 0)
    expect r[0] == [2, 4, 6]
    expect r[1] == [1, 3, 5]

test "chunk splits into pieces of at most n":
    expect chunk([1, 2, 3, 4, 5, 6, 7], 3) == [[1, 2, 3], [4, 5, 6], [7]]
    expect chunk([], 2) == []
    expect chunk([1, 2], 5) == [[1, 2]]

test "they compose with the existing tools":
    make nums = [1, 2, 3, 4, 5, 6, 7, 8]
    expect sum(partition(nums, task(n): n % 2 == 0)[0]) == 20

test "bad input":
    expect error:
        show chunk([1, 2, 3], 0)
    expect error:
        show group_by(5, task(x): x)
    expect error:
        show min_by([1, 2], task(x): [x])
