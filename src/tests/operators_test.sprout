~ Operator overloading: a type can define plus / minus / multiply / divide / modulo,
~ equals (== and !=), compare (< <= > >=), and text (custom display).
~ A *_test.sprout file, gated via `sprout test`.

type Frac:
    make num
    make den
    task plus(self, other):
        give Frac(self.num * other.den + other.num * self.den, self.den * other.den)
    task multiply(self, other):
        give Frac(self.num * other.num, self.den * other.den)
    task value(self):
        give self.num / self.den
    task compare(self, other):
        give self.value() - other.value()
    task equals(self, other):
        give self.num * other.den == other.num * self.den
    task text(self):
        give self.num + "/" + self.den

test "arithmetic operators dispatch to methods":
    expect (Frac(1, 2) + Frac(1, 3)).value() == 5 / 6
    expect (Frac(1, 2) * Frac(1, 3)).value() == 1 / 6

test "equals controls == and !=":
    expect Frac(1, 2) == Frac(2, 4)
    expect (Frac(1, 2) == Frac(1, 3)) == no
    expect Frac(1, 2) != Frac(1, 3)

test "compare controls < <= > >=":
    expect Frac(1, 3) < Frac(1, 2)
    expect Frac(1, 2) > Frac(1, 3)
    expect Frac(1, 2) <= Frac(2, 4)
    expect Frac(2, 4) >= Frac(1, 2)

test "text gives a custom display, even inside a list":
    expect "" + Frac(3, 4) == "3/4"
    expect "" + [Frac(1, 2), Frac(3, 4)] == "[1/2, 3/4]"

test "built-in operators are unchanged":
    expect 2 + 3 == 5
    expect 10 - 4 == 6
    expect "a" + "b" == "ab"
    expect [1, 2] == [1, 2]
    expect {a: 1} == {a: 1}
    expect 5 > 3
    expect "abc" < "abd"
    expect [1, 2] != [1, 3]
