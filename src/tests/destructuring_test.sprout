~ Destructuring: make a, b = pair — unpack a list into several names at once.
~ The list length must match the number of names. A *_test.sprout file (`sprout test`).

test "unpack a pair":
    make a, b = [1, 2]
    expect a == 1
    expect b == 2

test "unpack three":
    make x, y, z = [10, 20, 30]
    expect x + y + z == 60

test "unpack a computed list (with a slice)":
    make lo, hi = sort([4, 9, 1, 7])[0:2]
    expect lo == 1
    expect hi == 4

test "count must match the list length":
    expect error:
        make p, q = [1, 2, 3]

test "the right side must be a list":
    expect error:
        make m, n = 5
