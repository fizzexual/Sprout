# ==============================================================================
# Git Line Endings Configuration
# ==============================================================================

# Keep line endings consistent across machines (stored as LF in the repo).
* text=auto

# Windows scripts must keep CRLF endings to run correctly.
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ==============================================================================
# GitHub Linguist Override (The Sprout Flex)
# ==============================================================================

# Explicitly register .sprout files as a distinct language and make it detectable
*.sprout linguist-language=Sprout
*.sprout linguist-detectable=true

# Ignore the compiler engine and tests in the language statistics bar chart 
# so that the repository shows Sprout as the primary language.
src/**/*.ts linguist-vendored
test/**/*.ts linguist-vendored
