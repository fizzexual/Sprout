# ==============================================================================
# Git Line Endings Configuration
# ==============================================================================

# Keep line endings consistent across machines (stored as LF in the repo).
* text=auto

# Windows scripts must keep CRLF endings to run correctly.
*.cmd text eol=crlf

# Shell scripts must stay LF so they run on Linux/macOS CI runners.
*.sh text eol=lf

# ==============================================================================
# GitHub Linguist Override — show the Languages bar as C
# ==============================================================================
# Sprout's interpreter is written in C. The playground (HTML/JS), its server (Python),
# the build & installer scripts (Shell / Batchfile / Inno Setup), the .sprout examples, and
# the docs are all tooling around it. Count ONLY the C, so the Languages bar shows what the
# interpreter is implemented in (vendor everything, then un-vendor the C source).
* linguist-vendored
*.c linguist-vendored=false
*.h linguist-vendored=false
