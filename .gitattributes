# ==============================================================================
# Git Line Endings Configuration
# ==============================================================================

# Keep line endings consistent across machines (stored as LF in the repo).
* text=auto

# Windows scripts must keep CRLF endings to run correctly.
*.cmd text eol=crlf

# ==============================================================================
# GitHub Linguist Override (The Sprout Flex)
# ==============================================================================

# Register .sprout as a distinct language and make it detectable.
*.sprout linguist-language=Sprout
*.sprout linguist-detectable=true

# The interpreter is written in C, but we vendor it so the repo's language bar
# highlights Sprout itself rather than its implementation language.
src/**/*.c linguist-vendored
src/**/*.h linguist-vendored
